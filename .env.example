# Required: Uniswap v4 PoolManager address for the target chain
# Sepolia: 0xE03A1074c86CFeDd5C142C4F04F1a1536e203543
# Mainnet: 0x000000000004444c5dc75cB358380D2e3dE08A90
POOL_MANAGER=

# DSA/DSB are plain transferable ERC20s. There is no token-layer whitelist
# for Permit2, Universal Router, GMGN, or external venues.

# Optional: per-pool first-buy size in wei. Default = ANTI_SNIPE_MAX_BUY_WEI
# (0.001 ETH = 1000000000000000). Must be <= cap. Set to 0 to skip first-buy.
FIRST_BUY=

# RPC endpoints and deployer key are passed via forge flags:
#   forge script script/DeployDoubleSine.s.sol \
#     --rpc-url $SEPOLIA_RPC \
#     --private-key $DEPLOYER_PK \
#     --broadcast
